npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===== Environment Variables =====
.env
.env.local
.env.development
.env.test
.env.production
.env*.local

# ===== IDE & Editors =====
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# ===== OS Generated =====
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ===== Logs =====
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===== Build & Distribution =====
dist/
build/
out/

# ===== Testing =====
coverage/
.nyc_output/

# ===== Cache =====
.cache/
.temp/
temp/
tmp/
*.tmp

# ===== Flutter Specific =====
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
*.iml
.metadata
.packages
pubspec.lock

# Flutter build outputs
**/build/
*.apk
*.aab
*.ipa
*.app
*.dSYM.zip
*.dSYM

