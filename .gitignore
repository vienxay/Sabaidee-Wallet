*.keystore
*.jks
*.pem
*.p12
*.key
*.crt
*.cer
google-services.json
GoogleService-Info.plist
key.properties

# ===== Android Specific =====
**/android/.gradle/
**/android/local.properties
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/android/captures/
**/android/.cxx/

