# ================================
# Backend (Node.js) .gitignore
# ================================

# ===== Dependencies =====
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===== Environment Variables =====
.env
.env.local
.env.development
.env.test
.env.production
.env*.local

# ===== IDE & Editors =====
.vscode/
.idea/
*.swp
*.swo
*~

# ===== OS Generated =====
.DS_Store
Thumbs.db
Desktop.ini

# ===== Logs =====
logs/
*.log

# ===== Build =====
dist/
build/
out/

# ===== Testing =====
coverage/
.nyc_output/

# ===== Cache =====
.cache/
temp/
tmp/

# ===== Secrets & Keys =====
*.pem
*.key
*.crt
*.p12

# ===== Database =====
*.sqlite
*.sqlite3
*.db

# ===== Uploads (if stored locally) =====
uploads/
!uploads/.gitkeep