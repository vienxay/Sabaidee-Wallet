# ສ້າງ wallet ໃໝ່ໃນ LNBits ແລ້ວເອົາ keys ມາໃສ່ນີ້
POOL_WALLET_ID=192e0430e3e2490893ff059be7a8aafe
POOL_WALLET_ADMIN_KEY=0e4317dbce3f430c9c133a490c93b58a
POOL_WALLET_INVOICE_KEY=9cfcd26dea484890819497a5f32fc462

# ========================================
# BANK API CONFIGURATION (Sabaidee Wallet Company Account)
# ========================================

