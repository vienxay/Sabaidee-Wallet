# ========================================
# SABAIDEE WALLET - ENVIRONMENT VARIABLES
# ========================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/sabaidee-wallet

# JWT
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRE=30d

# ========================================
# LNBITS CONFIGURATION
# ========================================
LNBITS_URL=https://your-lnbits-instance.com
LNBITS_ADMIN_KEY=your-master-admin-key

# ========================================
# POOL WALLET (Admin)
# ========================================
